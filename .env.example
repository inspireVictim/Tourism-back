# ---------- App ----------
APP_NAME=NomadAI
APP_ENV=development

# ---------- Database ----------
DATABASE_URL=sqlite:///./sqlite3.db

# ---------- OpenRouter AI ----------
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model for /ai/consult (can be overridden per request)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional attribution headers recommended by OpenRouter docs
OPENROUTER_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=NomadAI

# Optional default system behavior for assistant
OPENROUTER_SYSTEM_PROMPT=You are NomadAI travel consultant. Help users choose tours, explain prices, and answer safely.
