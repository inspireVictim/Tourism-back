# ---------- App ----------
APP_NAME=NomadAI
APP_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- Database ----------
DATABASE_URL=sqlite:///./sqlite3.db

# ---------- OpenRouter AI ----------
